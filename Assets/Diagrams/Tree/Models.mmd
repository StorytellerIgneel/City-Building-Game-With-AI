    D1 --> StartSessionReq[StartSessionRequests]

    %% Responses
    D --> D2[Responses]
    D2 --> AIRes[AIResponse]
    AIRes --> AdviceRes[AdviceResponse]
    AIRes --> ObjectiveRes[ObjectiveResponse]
    AIRes --> ReactionRes[ReactionResponse]

    D2 --> PredictRes[PredictResponse]
    D2 --> StartSessionRes[StartSessionResponse]